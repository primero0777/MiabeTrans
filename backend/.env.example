# Copier ce fichier en .env et remplir les valeurs réelles
# cp .env.example .env

# ─── Base de données MySQL ────────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=miabetrans_db
DB_USER=root
DB_PASS=

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_with_a_long_random_string
JWT_EXPIRATION=86400

# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_URL=http://localhost/miabetrans/backend/api
