# ─── Variables d'environnement (SECRETS – ne jamais committer) ───────────────
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*
!frontend/.env.example
!backend/.env.example

# ─── Uploads utilisateurs (photos profil, docs) ──────────────────────────────
uploads/
backend/uploads/
frontend/public/uploads/

# ─── Dépendances ─────────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/

# ─── Build frontend ──────────────────────────────────────────────────────────
frontend/dist/
frontend/dist-ssr/

# ─── Cache Vite / outils ─────────────────────────────────────────────────────
frontend/.vite/
frontend/*.local

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Système d'exploitation ──────────────────────────────────────────────────
